{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile Current File",
			"type": "shell",
			"command": "jelly ${relativeFile} --export --out ./build/",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		},
		{
			"label": "Compile All",
			"type": "shell",
			"command": "find . -name '*.jelly' -not -path './.git/*' -exec jelly {} --export --out ./build/ \\;",
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		}
	]
}
